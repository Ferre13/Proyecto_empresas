# Base de Datos y Redis (Valores default de docker-compose)
DATABASE_URL=postgresql://postgres:postgres@db:5432/ap_automation
REDIS_URL=redis://redis:6379/0

# Seguridad: Supabase JWT (Obtener de tu panel de Supabase)
SUPABASE_JWT_SECRET=tu_secreto_de_supabase_aqui

# IA: Gemini (Obtener de Google AI Studio)
GEMINI_API_KEY=tu_api_key_de_google_aqui

# Billing: Stripe (Obtener de Stripe Dashboard en modo Test)
STRIPE_SECRET_KEY=sk_test_tu_clave_aqui
STRIPE_WEBHOOK_SECRET=whsec_tu_clave_aqui
